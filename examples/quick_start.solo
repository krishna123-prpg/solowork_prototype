// Declare variables
let x = 10;
let mut count = 0;
let greeting = "hello";

// Arithmetic
let result = x * 2 + 5;

// Print
print greeting;
print result;

// While loop
while(count != 3) {
    count = count + 1;
    print count;
}

// Conditional
if(result > 20) {
    print "big";
} else {
    print "small";
}
